{
  "version": 1,
  "ui": {
    "app_title": "Dashboard Productos",
    "subtitle": "Demo KPI, tablas y graficas para ventas de productos"
  },
  "csv_options": {
    "base_dir": "csv",
    "delimiter": ";",
    "decimal": ",",
    "encoding": "utf-8-sig",
    "dayfirst": true
  },
  "dashboard": {
    "title": "Dashboard Productos",
    "description": "Plantilla demo para explorar ventas de productos.",
    "allow_user_builder": true,
    "runtime": {
      "strategy": "service_api",
      "mode": "server",
      "dashboard_only": true,
      "data_backend": "polars",
      "query_scope": {
        "date_column": "APERTURA",
        "start": "01/05/2025",
        "end": "31/05/2025",
        "order": "desc"
      },
      "max_rows": 50000,
      "force_safe_template": false
    },
    "defaults": {
      "analysis_mode": "categorias",
      "x_column": "PRODUCTO",
      "y_column": "PRECIO",
      "date_column": "APERTURA",
      "aggregation": "count",
      "chart_type": "bar",
      "date_granularity": "month",
      "top_n": 15,
      "point_limit": 150,
      "table_limit": 200,
      "sort_dir": "desc"
    },
    "active_template_id": "demo-productos",
    "templates": [
      {
        "id": "demo-productos",
        "name": "Demo Productos",
        "title": "Ventas de Productos",
        "description": "KPIs de conteo y precio promedio, con tendencia y detalle.",
        "layout": {
          "rows": [
            {
              "id": "row_1",
              "columns": 3,
              "cells": [
                { "id": "cell_1_1" },
                { "id": "cell_1_2" },
                { "id": "cell_1_3" }
              ]
            },
            {
              "id": "row_2",
              "columns": 2,
              "cells": [
                { "id": "cell_2_1" },
                { "id": "cell_2_2" }
              ]
            },
            {
              "id": "row_3",
              "columns": 1,
              "cells": [
                { "id": "cell_3_1" }
              ]
            }
          ]
        },
        "widgets": [
          {
            "id": "kpi_registros",
            "cell_id": "cell_1_1",
            "type": "kpi",
            "title": "Registros",
            "column": "APERTURA",
            "aggregation": "count",
            "format": "integer",
            "accent_color": "#1d4ed8"
          },
          {
            "id": "kpi_precio_promedio",
            "cell_id": "cell_1_2",
            "type": "kpi",
            "title": "Precio promedio",
            "column": "PRECIO",
            "aggregation": "avg",
            "format": "number",
            "accent_color": "#0f766e"
          },
          {
            "id": "kpi_catalogo_promedio",
            "cell_id": "cell_1_3",
            "type": "kpi",
            "title": "Catalogo promedio",
            "column": "PRECIOCATALOGO",
            "aggregation": "avg",
            "format": "number",
            "accent_color": "#ea580c"
          },
          {
            "id": "chart_top_productos",
            "cell_id": "cell_2_1",
            "type": "chart",
            "title": "Top productos por tickets",
            "analysis_mode": "categorias",
            "chart_type": "bar",
            "x_column": "PRODUCTO",
            "y_column": "PRECIO",
            "date_column": "APERTURA",
            "aggregation": "count",
            "date_granularity": "month",
            "top_n": 15,
            "point_limit": 150,
            "filters": []
          },
          {
            "id": "chart_tendencia_mensual",
            "cell_id": "cell_2_2",
            "type": "chart",
            "title": "Tendencia mensual",
            "analysis_mode": "tendencia",
            "chart_type": "line",
            "x_column": "PRODUCTO",
            "y_column": "PRECIO",
            "date_column": "APERTURA",
            "aggregation": "count",
            "date_granularity": "month",
            "top_n": 12,
            "point_limit": 150,
            "filters": []
          },
          {
            "id": "table_detalle",
            "cell_id": "cell_3_1",
            "type": "table",
            "title": "Detalle de productos",
            "columns": [
              "APERTURA",
              "HORA",
              "PRODUCTO",
              "GRUPO",
              "CLASIFICACION",
              "PRECIO",
              "MESERO"
            ],
            "limit": 200,
            "sort_by": "APERTURA",
            "sort_dir": "desc",
            "filters": []
          }
        ],
        "global_filters": [],
        "date_range": {
          "enabled": false,
          "column": "APERTURA",
          "start": "",
          "end": ""
        }
      } 
    ]
  },
  "dashboard_modular": {
    "enabled": true,
    "template_id": "ventas-modular",
    "template_name": "Productos Modular",
    "title": "Dashboard Productos Modular",
    "description": "Dashboard modular adaptado al CSV de ventas por producto.",
    "layout_rows": [4, 3, 2, 1],
    "widgets": [
      {
        "factory": "kpi_sum",
        "cell": "cell_1_1",
        "id": "kpi_venta_total",
        "title": "Venta total",
        "column": "TOTAL",
        "format": "currency",
        "accent_color": "#1d4ed8"
      },
      {
        "factory": "kpi_count",
        "cell": "cell_1_2",
        "id": "kpi_registros",
        "title": "Registros",
        "column": "APERTURA",
        "format": "integer",
        "accent_color": "#0f766e"
      },
      {
        "factory": "kpi_avg",
        "cell": "cell_1_3",
        "id": "kpi_precio_promedio",
        "title": "Precio promedio",
        "column": "PRECIO",
        "format": "number",
        "accent_color": "#ea580c"
      },
      {
        "factory": "kpi_max",
        "cell": "cell_1_4",
        "id": "kpi_venta_maxima",
        "title": "Venta maxima",
        "column": "TOTAL",
        "format": "currency",
        "accent_color": "#7c3aed"
      },
      {
        "factory": "bar",
        "cell": "cell_2_1",
        "id": "chart_top_productos",
        "title": "Top productos por venta",
        "x_column": "PRODUCTO",
        "y_column": "TOTAL",
        "aggregation": "sum",
        "top_n": 10
      },
      {
        "factory": "kpi_sum",
        "cell": "cell_2_2",
        "id": "kpi_cantidad_total",
        "title": "Cantidad total",
        "column": "CANTIDAD",
        "format": "integer",
        "accent_color": "#0891b2"
      },
      {
        "factory": "linea",
        "cell": "cell_2_3",
        "id": "chart_tendencia_diaria",
        "title": "Tendencia diaria",
        "x_column": "APERTURA",
        "y_column": "TOTAL",
        "date_column": "APERTURA",
        "analysis_mode": "tendencia",
        "aggregation": "sum",
        "date_granularity": "day"
      },
      {
        "factory": "barra_lateral",
        "cell": "cell_3_1",
        "id": "chart_subtotal_por_grupo",
        "title": "Subtotal por grupo",
        "x_column": "GRUPO",
        "y_column": "SUBTOTAL",
        "aggregation": "sum",
        "top_n": 10
      },
      {
        "factory": "dona",
        "cell": "cell_3_2",
        "id": "chart_clasificacion",
        "title": "Clasificacion de productos",
        "x_column": "CLASIFICACION",
        "y_column": "APERTURA",
        "date_column": "APERTURA",
        "aggregation": "count",
        "top_n": 10
      },
      {
        "factory": "tabla",
        "cell": "cell_4_1",
        "id": "tabla_detalle_productos",
        "title": "Detalle de productos",
        "columns": [
          "APERTURA",
          "HORA",
          "PRODUCTO",
          "GRUPO",
          "CLASIFICACION",
          "CANTIDAD",
          "PRECIO",
          "TOTAL",
          "MESERO"
        ],
        "sort_by": "APERTURA",
        "sort_dir": "desc",
        "limit": 100
      }
    ]
  }
}
